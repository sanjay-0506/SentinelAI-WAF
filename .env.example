# Application
APP_NAME=AI-WAF
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
MAX_REQUEST_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=100

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=wafdb
POSTGRES_USER=wafuser
POSTGRES_PASSWORD=wafpassword
DATABASE_URL=postgresql+asyncpg://wafuser:wafpassword@postgres:5432/wafdb

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
STATS_CACHE_TTL=5

# Target Applications
JUICE_SHOP_URL=http://juice-shop:3000
DVWA_URL=http://dvwa:80

# NGINX
NGINX_HOST=localhost
NGINX_PORT=80

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api/v1
